+// Função auxiliar para pegar usuario_id da sessão
+// Retorna 0 se não encontrar ou erro
+func verificaSessao(c echo.Context) (int32, error) {
+	sessao, err := session.Get("sessao", c)
+	if err != nil {
+		// Trata erro de backend da sessão (ex: store indisponível)
+		fmt.Printf("Erro ao obter sessão: %v\n", err)
+		// Não retorna erro fatal aqui, pois pode ser sessão inválida/expirada
+		// Retorna 0 e nil para indicar 'não logado' ou erro recuperável.
+		return 0, nil
+	}
+
+	if sessao.Values["usuario_id"] == nil {
+		return 0, nil // Não logado
+	}
+
+	// Tenta converter para int32
+	userID64, ok := sessao.Values["usuario_id"].(int64) // pgstore pode usar int64
+	if !ok {
+		// Tenta converter de int se não for int64
+		userIDInt, okInt := sessao.Values["usuario_id"].(int)
+		if !okInt {
+			// Se não for nem int64 nem int, algo está errado com o tipo na sessão
+			fmt.Printf("Erro: tipo inesperado para usuario_id na sessão: %T\n", sessao.Values["usuario_id"])
+			// Invalida a sessão?
+			sessao.Options.MaxAge = -1
+			_ = sessao.Save(c.Request(), c.Response().Writer)
+			return 0, fmt.Errorf("tipo inválido para usuario_id na sessão")
+		}
+		return int32(userIDInt), nil
+	}
+
+	return int32(userID64), nil
+}
